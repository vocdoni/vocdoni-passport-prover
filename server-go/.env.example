# Docker Compose runtime template.
# Copy to .env and set VOCDONI_PUBLIC_BASE_URL to a phone-reachable URL before starting the server.
VOCDONI_PUBLIC_BASE_URL=http://192.168.1.10:8080

HOST_PORT=8080
SERVER_IMAGE=vocdoni-passport-server
COMPOSE_PROJECT_NAME=vocdoni-passport-server-v2

# Barretenberg CPU target.
# Passed to bb as TARGET_ARCH / compiler -march on x86-64.
# - native: build for the CPU running docker build
# - x86-64-v2: broad compatibility (Intel Nehalem/Westmere+, AMD Bulldozer+/Zen)
# - x86-64-v3: AVX2/FMA/BMI2-era CPUs (Intel Haswell+, AMD Zen family)
# - skylake: Intel Skylake/Cascade Lake class baseline
# - x86-64-v4: AVX-512-class CPUs only (Intel Ice Lake+/Sapphire Rapids, AVX-512-capable Zen 4 systems)
# On arm64/aarch64, bb uses its ARM build path and ignores this x86-specific setting.
BB_TARGET_ARCH=native

# CPU tuning only. Does not change the required instruction set.
# Use generic for portable images, or native when building for the local machine only.
BB_TUNE_ARCH=native

VOCDONI_SERVER_LISTEN=0.0.0.0:8080
VOCDONI_LOG_LEVEL=info
VOCDONI_APK_PATH=/opt/vocdoni/downloads/app-release.apk
VOCDONI_PROVER_LOW_MEMORY_MODE=false
VOCDONI_PROVER_MAX_STORAGE_USAGE=200000000
VOCDONI_PROVER_TIMEOUT=20m
VOCDONI_PROVER_MAX_CONCURRENCY=8

VOCDONI_PROVER_BINARY_PATH=/opt/vocdoni/bin/prover-cli
BB_BINARY_PATH=/usr/local/bin/bb
VOCDONI_WORKSPACE_ROOT=/opt/vocdoni/repos/vocdoni-passport-prover
VOCDONI_ARTIFACTS_DIR=/opt/vocdoni/repos/vocdoni-passport-prover/artifacts/registry/minimal-default-0.16.0

# MongoDB settings
VOCDONI_MONGODB_URI=mongodb://mongo:27017
VOCDONI_MONGODB_DATABASE=vocdoni_passport
