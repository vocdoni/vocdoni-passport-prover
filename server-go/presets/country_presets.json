{
  "version": "1.0.0",
  "presets": {
    "generic": {
      "id": "generic",
      "name": "Generic (All Countries)",
      "description": "Standard fields available in most ICAO 9303 compliant documents",
      "countries": [],
      "documentTypes": ["passport", "id_card"],
      "fields": {
        "mrz": {
          "nationality": {
            "label": "Nationality",
            "description": "3-letter country code (e.g., ESP, FRA, DEU)",
            "example": "ESP",
            "available": true
          },
          "issuing_country": {
            "label": "Issuing Country",
            "description": "Country that issued the document",
            "example": "ESP",
            "available": true
          },
          "firstname": {
            "label": "First Name",
            "description": "Given name(s) as shown in MRZ",
            "example": "JUAN",
            "available": true
          },
          "lastname": {
            "label": "Last Name",
            "description": "Surname(s) as shown in MRZ",
            "example": "GARCIA LOPEZ",
            "available": true
          },
          "fullname": {
            "label": "Full Name",
            "description": "Complete name from MRZ",
            "example": "GARCIA LOPEZ, JUAN",
            "available": true
          },
          "birthdate": {
            "label": "Date of Birth",
            "description": "Birth date in YYMMDD format",
            "example": "850315",
            "available": true
          },
          "expiry_date": {
            "label": "Expiry Date",
            "description": "Document expiration date",
            "example": "280315",
            "available": true
          },
          "document_number": {
            "label": "Document Number",
            "description": "Official document identifier",
            "example": "AB1234567",
            "available": true
          },
          "document_type": {
            "label": "Document Type",
            "description": "Type of travel document (P=Passport, I=ID Card)",
            "example": "P",
            "available": true
          },
          "gender": {
            "label": "Gender",
            "description": "M=Male, F=Female, X=Unspecified",
            "example": "M",
            "available": true
          },
          "optional_data_1": {
            "label": "Optional Data 1",
            "description": "Country-specific optional field (TD1: chars 15-29, TD3: chars 71-84)",
            "example": "Varies by country",
            "available": true
          },
          "optional_data_2": {
            "label": "Optional Data 2",
            "description": "Second optional field (TD1 only: line 2, chars 18-28)",
            "example": "Varies by country",
            "available": true,
            "td1Only": true
          }
        }
      },
      "constraints": {
        "nationality": { "configurable": true },
        "issuing_country": { "configurable": true },
        "age": { "configurable": true }
      }
    },
    "esp_dni": {
      "id": "esp_dni",
      "name": "Spanish DNI",
      "description": "Spanish National ID Card (Documento Nacional de Identidad)",
      "countries": ["ESP"],
      "documentTypes": ["id_card"],
      "fields": {
        "mrz": {
          "nationality": {
            "label": "Nationality",
            "description": "Always ESP for Spanish DNI",
            "example": "ESP",
            "available": true,
            "fixed": true,
            "fixedValue": "ESP"
          },
          "issuing_country": {
            "label": "Issuing Country",
            "description": "Always ESP for Spanish DNI",
            "example": "ESP",
            "available": true,
            "fixed": true,
            "fixedValue": "ESP"
          },
          "firstname": {
            "label": "Nombre",
            "description": "Given name(s)",
            "example": "JUAN CARLOS",
            "available": true
          },
          "lastname": {
            "label": "Apellidos",
            "description": "First and second surname",
            "example": "GARCIA LOPEZ",
            "available": true
          },
          "fullname": {
            "label": "Nombre Completo",
            "description": "Full name as in DNI",
            "example": "GARCIA LOPEZ, JUAN CARLOS",
            "available": true
          },
          "birthdate": {
            "label": "Fecha de Nacimiento",
            "description": "Birth date",
            "example": "850315",
            "available": true
          },
          "expiry_date": {
            "label": "Fecha de Caducidad",
            "description": "Expiry date",
            "example": "280315",
            "available": true
          },
          "document_number": {
            "label": "Número de Soporte",
            "description": "Support number (not the DNI number)",
            "example": "AAA123456",
            "available": true
          },
          "document_type": {
            "label": "Tipo de Documento",
            "description": "ID Card type",
            "example": "ID",
            "available": true
          },
          "gender": {
            "label": "Sexo",
            "description": "M=Masculino, F=Femenino",
            "example": "M",
            "available": true
          },
          "dni_number": {
            "label": "Número de DNI",
            "description": "Spanish DNI number with letter (stored in Optional Data 1)",
            "example": "12345678Z",
            "available": true,
            "mapsTo": "optional_data_1",
            "mrzPosition": { "start": 15, "end": 24 }
          }
        }
      },
      "constraints": {
        "nationality": { 
          "configurable": false, 
          "fixed": true,
          "fixedValue": { "in": ["ESP"] }
        },
        "issuing_country": { 
          "configurable": false, 
          "fixed": true,
          "fixedValue": { "in": ["ESP"] }
        },
        "age": { "configurable": true }
      }
    },
